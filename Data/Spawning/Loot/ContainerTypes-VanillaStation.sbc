    <!-- ==================== ASSEMBLER ==================== -->
    <ContainerType CountMin="3" CountMax="8">
      <Id>
        <TypeId>ContainerTypeDefinition</TypeId>
        <SubtypeId>VanillaStation-CT-Assembler</SubtypeId>
      </Id>
      <Items>
