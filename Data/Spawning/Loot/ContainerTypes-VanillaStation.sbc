        <TypeId>ContainerTypeDefinition</TypeId>
        <SubtypeId>VanillaStation-CT-LargeCargo</SubtypeId>
      </Id>
      <Items>
        <Item AmountMin="100" AmountMax="500">
          <Frequency>8.0</Frequency>
